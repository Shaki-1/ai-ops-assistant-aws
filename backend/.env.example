# AI Ops Assistant - Environment Variables Configuration
PORT=3000

# OpenAI API Settings
OPENAI_API_KEY=your_openai_api_key_here

# Optional: Custom model (Defaults to gpt-4o-mini if not specified)
# OPENAI_MODEL=gpt-4o-mini

# Optional: Custom base URL (e.g. for local models like Ollama, LM Studio, or Azure)
# OPENAI_BASE_URL=https://api.openai.com/v1
