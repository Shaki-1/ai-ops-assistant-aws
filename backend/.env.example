# AI Ops Assistant - Environment Variables Configuration
PORT=3000

# Active AI Provider: "openai" or "ollama" (Defaults to "openai")
AI_PROVIDER=openai

# ==========================================
# 1. OpenAI Configuration Options
# ==========================================
OPENAI_API_KEY=your_openai_api_key_here

# Optional OpenAI parameters:
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://api.openai.com/v1

# ==========================================
# 2. Ollama Configuration Options
# ==========================================
# The model name loaded inside your local Ollama runtime (e.g. llama3, mistral, qwen2.5-coder)
OLLAMA_MODEL=llama3

# Optional Ollama parameters (Defaults to http://localhost:11434 if not specified)
# OLLAMA_BASE_URL=http://localhost:11434
